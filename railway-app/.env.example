# Railway に設定する環境変数（.envファイルとしてではなくRailwayのダッシュボードで設定）

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=yourname/ponshutagram-sake

# Google OAuth2（auth_setup.py を実行して取得）
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxx

# Google My Business（auth_setup.py を実行して取得）
GMB_LOCATION=accounts/123456789/locations/987654321
